datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

model Certificate {
  id             String   @id @default(cuid())
  title          String
  platform       String
  category       String?
  certificateUrl String?
  description    String?
  imageUrl       String?
  link           String?
  issuedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
