datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

model Certificate {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  courseName     String
  platform       String
  category       String?
  duration       String?
  pricingType    String   @default("FREE")
  courseContent  String?
  benefits       String?
  certificateUrl String?
  description    String?
  imageUrl       String?
  link           String?
  metaTitle      String?
  metaDescription String?
  keywords       String?
  issuedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
